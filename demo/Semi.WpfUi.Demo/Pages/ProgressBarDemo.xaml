<UserControl
    x:Class="Semi.WpfUi.Demo.Pages.ProgressBarDemo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:attached="clr-namespace:Semi.WpfUi.Attached;assembly=Semi.WpfUi"
    xmlns:semi="clr-namespace:Semi.WpfUi.Controls;assembly=Semi.WpfUi">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <semi:StackPanel Margin="40,32" MaxWidth="860" Spacing="24">
            <semi:StackPanel Spacing="8">
                <TextBlock
                    FontSize="{DynamicResource SemiFontSizeHeader3}"
                    FontWeight="{DynamicResource SemiFontWeightBold}"
                    Foreground="{DynamicResource SemiColorText0}"
                    Text="ProgressBar" />
                <TextBlock
                    Foreground="{DynamicResource SemiColorText1}"
                    Text="Communicate the progress of a task with semantic colors and an indeterminate state." />
            </semi:StackPanel>

            <GroupBox Padding="16" Header="Progress">
                <semi:StackPanel Spacing="16">
                    <ProgressBar Maximum="100" Value="25" />
                    <ProgressBar Maximum="100" Value="50" />
                    <ProgressBar Maximum="100" Value="80" />
                    <ProgressBar Maximum="100" Value="100" />
                </semi:StackPanel>
            </GroupBox>

            <GroupBox Padding="16" Header="Semantic colors">
                <semi:StackPanel Spacing="16">
                    <ProgressBar Maximum="100" Value="64" />
                    <ProgressBar attached:Classes.Success="True" Maximum="100" Value="78" />
                    <ProgressBar attached:Classes.Warning="True" Maximum="100" Value="48" />
                    <ProgressBar attached:Classes.Danger="True" Maximum="100" Value="25" />
                </semi:StackPanel>
            </GroupBox>

            <GroupBox Padding="16" Header="Interactive and states">
                <semi:StackPanel Spacing="16">
                    <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="Use the slider to update the progress value." />
                    <ProgressBar Maximum="100" Value="{Binding ElementName=ValueSlider, Path=Value}" />
                    <Slider x:Name="ValueSlider" Maximum="100" Value="60" />
                    <ProgressBar IsIndeterminate="True" />
                    <ProgressBar IsEnabled="False" Maximum="100" Value="55" />
                </semi:StackPanel>
            </GroupBox>
        </semi:StackPanel>
    </ScrollViewer>
</UserControl>
