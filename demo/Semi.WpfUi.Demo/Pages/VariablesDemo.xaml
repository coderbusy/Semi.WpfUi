<UserControl x:Class="Semi.WpfUi.Demo.Pages.VariablesDemo" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32" MaxWidth="860">
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader3}" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Variables" />
            <TextBlock Margin="0,8,0,28" Foreground="{DynamicResource SemiColorText1}" Text="Core sizing, spacing, typography and border-radius design tokens." />
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader6}" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Control heights" />
            <WrapPanel Margin="0,16,0,32"><Border Width="120" Height="{DynamicResource SemiHeightControlSmall}" Margin="0,0,12,12" Background="{DynamicResource SemiColorPrimaryLight}" CornerRadius="{DynamicResource SemiBorderRadiusSmall}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Small · 24" /></Border><Border Width="120" Height="{DynamicResource SemiHeightControlDefault}" Margin="0,0,12,12" Background="{DynamicResource SemiColorPrimaryLight}" CornerRadius="{DynamicResource SemiBorderRadiusSmall}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Default · 32" /></Border><Border Width="120" Height="{DynamicResource SemiHeightControlLarge}" Background="{DynamicResource SemiColorPrimaryLight}" CornerRadius="{DynamicResource SemiBorderRadiusSmall}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Large · 40" /></Border></WrapPanel>
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader6}" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Spacing" />
            <StackPanel Margin="0,16,0,32"><StackPanel Orientation="Horizontal"><TextBlock Width="140" VerticalAlignment="Center" Text="SemiSpacingTight" /><Border Width="{DynamicResource SemiSpacingTight}" Height="16" Background="{DynamicResource SemiColorPrimary}" /><TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="8" /></StackPanel><StackPanel Margin="0,12,0,0" Orientation="Horizontal"><TextBlock Width="140" VerticalAlignment="Center" Text="SemiSpacingBase" /><Border Width="{DynamicResource SemiSpacingBase}" Height="16" Background="{DynamicResource SemiColorPrimary}" /><TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="16" /></StackPanel><StackPanel Margin="0,12,0,0" Orientation="Horizontal"><TextBlock Width="140" VerticalAlignment="Center" Text="SemiSpacingLoose" /><Border Width="{DynamicResource SemiSpacingLoose}" Height="16" Background="{DynamicResource SemiColorPrimary}" /><TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="24" /></StackPanel><StackPanel Margin="0,12,0,0" Orientation="Horizontal"><TextBlock Width="140" VerticalAlignment="Center" Text="SemiSpacingExtraLoose" /><Border Width="{DynamicResource SemiSpacingExtraLoose}" Height="16" Background="{DynamicResource SemiColorPrimary}" /><TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="32" /></StackPanel></StackPanel>
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader6}" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Corner radius" />
            <WrapPanel Margin="0,16,0,0"><Border Width="110" Height="56" Margin="0,0,12,12" Background="{DynamicResource SemiColorFill0}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="{DynamicResource SemiBorderRadiusSmall}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Small · 3" /></Border><Border Width="110" Height="56" Margin="0,0,12,12" Background="{DynamicResource SemiColorFill0}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="{DynamicResource SemiBorderRadiusMedium}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Medium · 6" /></Border><Border Width="110" Height="56" Background="{DynamicResource SemiColorFill0}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="{DynamicResource SemiBorderRadiusLarge}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Large · 12" /></Border></WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
