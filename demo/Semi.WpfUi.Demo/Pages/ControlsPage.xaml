<UserControl x:Class="Semi.WpfUi.Demo.Pages.ControlsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32" MaxWidth="860">
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader3}" FontWeight="{DynamicResource SemiFontWeightBold}" Foreground="{DynamicResource SemiColorText0}" Text="Buttons &amp; Selection" />
            <TextBlock Margin="0,8,0,28" Foreground="{DynamicResource SemiColorText1}" Text="Common action and selection controls in their key states." />
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader6}" FontWeight="{DynamicResource SemiFontWeightBold}" Foreground="{DynamicResource SemiColorText0}" Text="Button" />
            <WrapPanel Margin="0,16,0,32"><Button Margin="0,0,8,8" Content="Default" /><Button Margin="0,0,8,8" Content="Primary" /><Button Margin="0,0,8,8" Content="Danger" /><Button Margin="0,0,8,8" IsEnabled="False" Content="Disabled" /></WrapPanel>
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader6}" FontWeight="{DynamicResource SemiFontWeightBold}" Foreground="{DynamicResource SemiColorText0}" Text="CheckBox" />
            <WrapPanel Margin="0,16,0,32"><CheckBox Margin="0,0,20,8" Content="Unchecked" /><CheckBox Margin="0,0,20,8" IsChecked="True" Content="Checked" /><CheckBox Margin="0,0,20,8" IsThreeState="True" IsChecked="{x:Null}" Content="Indeterminate" /><CheckBox IsEnabled="False" Content="Disabled" /></WrapPanel>
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader6}" FontWeight="{DynamicResource SemiFontWeightBold}" Foreground="{DynamicResource SemiColorText0}" Text="RadioButton &amp; ToggleButton" />
            <WrapPanel Margin="0,16,0,0"><RadioButton Margin="0,0,20,8" GroupName="Framework" IsChecked="True" Content="WPF" /><RadioButton Margin="0,0,20,8" GroupName="Framework" Content="Avalonia" /><RadioButton Margin="0,0,20,8" GroupName="Framework" Content="WinUI" /><ToggleButton Margin="0,0,8,8" Content="Toggle off" /><ToggleButton IsChecked="True" Content="Toggle on" /></WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
