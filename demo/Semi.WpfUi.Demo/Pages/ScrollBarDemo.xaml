<UserControl
    x:Class="Semi.WpfUi.Demo.Pages.ScrollBarDemo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:semi="clr-namespace:Semi.WpfUi.Controls;assembly=Semi.WpfUi">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <semi:StackPanel Margin="40,32" MaxWidth="860" Spacing="24">
            <semi:StackPanel Spacing="8">
                <TextBlock FontSize="{DynamicResource SemiFontSizeHeader3}" FontWeight="{DynamicResource SemiFontWeightBold}" Foreground="{DynamicResource SemiColorText0}" Text="ScrollBar" />
                <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="Navigate overflowing content with horizontal and vertical Semi Design scroll bars." />
            </semi:StackPanel>

            <GroupBox Padding="16" Header="Orientation">
                <semi:Grid ColumnSpacing="32">
                    <semi:Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></semi:Grid.ColumnDefinitions>
                    <semi:StackPanel Spacing="12">
                        <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="Horizontal" />
                        <ScrollBar Width="240" HorizontalAlignment="Left" Maximum="100" Orientation="Horizontal" SmallChange="5" Value="35" ViewportSize="25" />
                        <ScrollBar Width="240" HorizontalAlignment="Left" IsEnabled="False" Maximum="100" Orientation="Horizontal" Value="55" ViewportSize="25" />
                    </semi:StackPanel>
                    <semi:StackPanel Grid.Column="1" Spacing="12">
                        <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="Vertical" />
                        <ScrollBar Height="180" Maximum="100" Orientation="Vertical" SmallChange="5" Value="35" ViewportSize="25" />
                    </semi:StackPanel>
                </semi:Grid>
            </GroupBox>

            <GroupBox Padding="16" Header="ScrollViewer">
                <semi:StackPanel Spacing="12">
                    <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="Both scroll bars appear when the content exceeds the viewport." />
                    <Border Height="240" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="{DynamicResource SemiBorderRadiusMedium}" ClipToBounds="True">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <UniformGrid Width="900" Height="420" Columns="4" Rows="2">
                                <Border Background="{DynamicResource SemiColorPrimaryLight}" /><Border Background="{DynamicResource SemiColorSuccessLight}" />
                                <Border Background="{DynamicResource SemiColorWarningLight}" /><Border Background="{DynamicResource SemiColorDangerLight}" />
                                <Border Background="{DynamicResource SemiColorFill0}" /><Border Background="{DynamicResource SemiColorFill1}" />
                                <Border Background="{DynamicResource SemiColorFill2}" /><Border Background="{DynamicResource SemiColorPrimaryLight}" />
                            </UniformGrid>
                        </ScrollViewer>
                    </Border>
                </semi:StackPanel>
            </GroupBox>
        </semi:StackPanel>
    </ScrollViewer>
</UserControl>
