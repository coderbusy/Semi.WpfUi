<UserControl x:Class="Semi.WpfUi.Demo.Pages.TextBlockDemo" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:att="clr-namespace:Semi.WpfUi.Attached;assembly=Semi.WpfUi">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32" MaxWidth="860">
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader3}" FontWeight="{DynamicResource SemiFontWeightBold}" Text="TextBlock" />
            <TextBlock Margin="0,8,0,28" att:Classes.Secondary="True" Text="Use attached Classes to apply Semi typography and semantic text states." />
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader6}" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Headings" />
            <StackPanel Margin="0,16,0,32">
                <TextBlock Style="{StaticResource TitleTextBlock}" att:Classes.H1="True" Text="Heading 1" />
                <TextBlock Margin="0,12,0,0" Style="{StaticResource TitleTextBlock}" att:Classes.H2="True" Text="Heading 2" />
                <TextBlock Margin="0,12,0,0" Style="{StaticResource TitleTextBlock}" att:Classes.H3="True" Text="Heading 3" />
                <TextBlock Margin="0,12,0,0" Style="{StaticResource TitleTextBlock}" att:Classes.H4="True" Text="Heading 4" />
                <TextBlock Margin="0,12,0,0" Style="{StaticResource TitleTextBlock}" att:Classes.H5="True" Text="Heading 5" />
                <TextBlock Margin="0,12,0,0" Style="{StaticResource TitleTextBlock}" att:Classes.H6="True" Text="Heading 6" />
            </StackPanel>
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader6}" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Semantic states" />
            <WrapPanel Margin="0,16,0,32"><TextBlock Margin="0,0,20,12" Text="Default" /><TextBlock Margin="0,0,20,12" att:Classes.Secondary="True" Text="Secondary" /><TextBlock Margin="0,0,20,12" att:Classes.Tertiary="True" Text="Tertiary" /><TextBlock Margin="0,0,20,12" att:Classes.Success="True" Text="Success" /><TextBlock Margin="0,0,20,12" att:Classes.Warning="True" Text="Warning" /><TextBlock Margin="0,0,20,12" att:Classes.Danger="True" Text="Danger" /><TextBlock Margin="0,0,20,12" att:Classes.Disabled="True" Text="Disabled" /></WrapPanel>
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader6}" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Decorations" />
            <WrapPanel Margin="0,16,0,0"><TextBlock Margin="0,0,20,12" att:Classes.Mark="True" Text="Marked text" /><TextBlock Margin="0,0,20,12" att:Classes.Underline="True" Text="Underlined text" /><TextBlock att:Classes.Delete="True" Text="Deleted text" /></WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
