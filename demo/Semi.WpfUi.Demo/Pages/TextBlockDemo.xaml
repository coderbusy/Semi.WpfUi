<UserControl x:Class="Semi.WpfUi.Demo.Pages.TextBlockDemo" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:att="clr-namespace:Semi.WpfUi.Attached;assembly=Semi.WpfUi">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Orientation="Horizontal">
            <GroupBox Width="400" Height="400" Margin="0,0,16,0" Header="Default Theme">
                <Grid Margin="12" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="130" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Margin="4" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Classes" /><TextBlock Grid.Row="1" Margin="4" Text="-" /><TextBlock Grid.Row="2" Margin="4" Text="Secondary" /><TextBlock Grid.Row="3" Margin="4" Text="Tertiary" /><TextBlock Grid.Row="4" Margin="4" Text="Quaternary" /><TextBlock Grid.Row="5" Margin="4" Text="Success" /><TextBlock Grid.Row="6" Margin="4" Text="Warning" /><TextBlock Grid.Row="7" Margin="4" Text="Danger" /><TextBlock Grid.Row="8" Margin="4" Text="Mark" /><TextBlock Grid.Row="9" Margin="4" Text="Underline" /><TextBlock Grid.Row="10" Margin="4" Text="Delete" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="4" Text="Text" /><TextBlock Grid.Row="2" Grid.Column="1" Margin="4" att:Classes.Secondary="True" Text="Secondary" /><TextBlock Grid.Row="3" Grid.Column="1" Margin="4" att:Classes.Tertiary="True" Text="Tertiary" /><TextBlock Grid.Row="4" Grid.Column="1" Margin="4" att:Classes.Quaternary="True" Text="Quaternary" /><TextBlock Grid.Row="5" Grid.Column="1" Margin="4" att:Classes.Success="True" Text="Success" /><TextBlock Grid.Row="6" Grid.Column="1" Margin="4" att:Classes.Warning="True" Text="Warning" /><TextBlock Grid.Row="7" Grid.Column="1" Margin="4" att:Classes.Danger="True" Text="Danger" /><TextBlock Grid.Row="8" Grid.Column="1" Margin="4" att:Classes.Mark="True" Text="Default Mark" /><TextBlock Grid.Row="9" Grid.Column="1" Margin="4" att:Classes.Underline="True" Text="Underline" /><TextBlock Grid.Row="10" Grid.Column="1" Margin="4" att:Classes.Delete="True" Text="Delete" />
                </Grid>
            </GroupBox>
            <GroupBox Width="400" Height="400" Header="Style: TitleTextBlock">
                <Grid Margin="12" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Margin="4" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Classes" /><TextBlock Grid.Row="1" Margin="4" Text="H1" /><TextBlock Grid.Row="2" Margin="4" Text="H2" /><TextBlock Grid.Row="3" Margin="4" Text="H3" /><TextBlock Grid.Row="4" Margin="4" Text="H4" /><TextBlock Grid.Row="5" Margin="4" Text="H5" /><TextBlock Grid.Row="6" Margin="4" Text="H6" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="4" Style="{StaticResource TitleTextBlock}" att:Classes.H1="True" Text="Header 1" /><TextBlock Grid.Row="2" Grid.Column="1" Margin="4" Style="{StaticResource TitleTextBlock}" att:Classes.H2="True" Text="Header 2" /><TextBlock Grid.Row="3" Grid.Column="1" Margin="4" Style="{StaticResource TitleTextBlock}" att:Classes.H3="True" Text="Header 3" /><TextBlock Grid.Row="4" Grid.Column="1" Margin="4" Style="{StaticResource TitleTextBlock}" att:Classes.H4="True" Text="Header 4" /><TextBlock Grid.Row="5" Grid.Column="1" Margin="4" Style="{StaticResource TitleTextBlock}" att:Classes.H5="True" Text="Header 5" /><TextBlock Grid.Row="6" Grid.Column="1" Margin="4" Style="{StaticResource TitleTextBlock}" att:Classes.H6="True" Text="Header 6" />
                </Grid>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
