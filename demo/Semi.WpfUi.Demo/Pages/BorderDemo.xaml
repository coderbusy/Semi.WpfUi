<UserControl
    x:Class="Semi.WpfUi.Demo.Pages.BorderDemo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:att="clr-namespace:Semi.WpfUi.Attached;assembly=Semi.WpfUi">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="920" Margin="24">
            <TextBlock
                FontSize="{DynamicResource SemiFontSizeHeader3}"
                FontWeight="{DynamicResource SemiFontWeightBold}"
                Text="Border" />
            <TextBlock
                Margin="0,8,0,24"
                Foreground="{DynamicResource SemiColorText1}"
                Text="CardBorder provides Semi card spacing, border, background and radius. Classes.Shadow and Classes.Hover add elevated and interaction-ready variants directly from the theme library." />

            <GroupBox Header="CardBorder">
                <WrapPanel Margin="16">
                    <Border
                        Width="260"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{DynamicResource SemiFontSizeHeader6}"
                                FontWeight="{DynamicResource SemiFontWeightBold}"
                                Text="Card" />
                            <TextBlock
                                Margin="0,8,0,0"
                                att:Classes.Secondary="True"
                                Text="Base card styling with Semi background, border and corner radius."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Width="260"
                        att:Classes.Shadow="True"
                        Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{DynamicResource SemiFontSizeHeader6}"
                                FontWeight="{DynamicResource SemiFontWeightBold}"
                                Text="Shadow Always Applied" />
                            <TextBlock
                                Margin="0,8,0,0"
                                att:Classes.Secondary="True"
                                Text="Apply Classes.Shadow to keep the card elevated in both themes."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Width="260"
                        att:Classes.Hover="True"
                        Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{DynamicResource SemiFontSizeHeader6}"
                                FontWeight="{DynamicResource SemiFontWeightBold}"
                                Text="Shadow On Hover" />
                            <TextBlock
                                Margin="0,8,0,0"
                                att:Classes.Secondary="True"
                                Text="Apply Classes.Hover to show the shadow only while the pointer is over the card."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
