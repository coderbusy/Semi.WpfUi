<UserControl
    x:Class="Semi.WpfUi.Demo.Pages.ListBoxDemo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:semi="clr-namespace:Semi.WpfUi.Controls;assembly=Semi.WpfUi">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <semi:StackPanel
            MaxWidth="860"
            Margin="24"
            Spacing="16">
            <semi:StackPanel Spacing="8">
                <TextBlock
                    FontSize="{DynamicResource SemiFontSizeHeader3}"
                    FontWeight="{DynamicResource SemiFontWeightBold}"
                    Text="ListBox" />
                <TextBlock Foreground="{DynamicResource SemiColorText1}" Text="用于展示并选择一组项目，支持单选、多选、禁用与自定义内容。" />
            </semi:StackPanel>
            <GroupBox Padding="16" Header="Single selection">
                <ListBox
                    Width="360"
                    HorizontalAlignment="Left"
                    SelectedIndex="1">
                    <ListBoxItem Content="设计规范" />
                    <ListBoxItem Content="组件开发" />
                    <ListBoxItem Content="主题与令牌" />
                    <ListBoxItem Content="已禁用的项目" IsEnabled="False" />
                </ListBox>
            </GroupBox>
            <GroupBox Padding="16" Header="Multiple selection">
                <ListBox
                    Width="360"
                    Height="190"
                    HorizontalAlignment="Left"
                    SelectionMode="Multiple">
                    <ListBoxItem Content="北京" IsSelected="True" />
                    <ListBoxItem Content="上海" />
                    <ListBoxItem Content="深圳" IsSelected="True" />
                    <ListBoxItem Content="杭州" />
                </ListBox>
            </GroupBox>
            <GroupBox Padding="16" Header="Custom content">
                <ListBox
                    Width="420"
                    HorizontalAlignment="Left"
                    SelectedIndex="0">
                    <ListBoxItem>
                        <semi:StackPanel Spacing="3">
                            <TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="Semi.WpfUi" />
                            <TextBlock
                                FontSize="{DynamicResource SemiFontSizeSmall}"
                                Foreground="{DynamicResource SemiColorText2}"
                                Text="WPF theme inspired by Semi Design" />
                        </semi:StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <semi:StackPanel Spacing="3">
                            <TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="Demo application" />
                            <TextBlock
                                FontSize="{DynamicResource SemiFontSizeSmall}"
                                Foreground="{DynamicResource SemiColorText2}"
                                Text="Explore controls in Light and Dark themes" />
                        </semi:StackPanel>
                    </ListBoxItem>
                </ListBox>
            </GroupBox>
            <GroupBox Padding="16" Header="Radio group themes">
                <semi:StackPanel Spacing="16">
                    <TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="RadioGroupListBox" />
                    <ListBox
                        Width="420"
                        HorizontalAlignment="Left"
                        SelectedIndex="0"
                        Style="{StaticResource RadioGroupListBox}">
                        <ListBoxItem Content="Avalonia" />
                        <ListBoxItem Content="WPF" />
                        <ListBoxItem Content="WinUI" />
                    </ListBox>
                    <TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="ButtonRadioGroupListBox" />
                    <ListBox
                        HorizontalAlignment="Left"
                        SelectedIndex="1"
                        Style="{StaticResource ButtonRadioGroupListBox}">
                        <ListBoxItem Content="日" />
                        <ListBoxItem Content="周" />
                        <ListBoxItem Content="月" />
                    </ListBox>
                    <TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="CardRadioGroupListBox" />
                    <ListBox
                        Width="420"
                        HorizontalAlignment="Left"
                        SelectedIndex="0"
                        Style="{StaticResource CardRadioGroupListBox}">
                        <ListBoxItem Content="基础方案" />
                        <ListBoxItem Content="专业方案" />
                    </ListBox>
                    <TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="PureCardRadioGroupListBox" />
                    <ListBox
                        Width="420"
                        HorizontalAlignment="Left"
                        SelectedIndex="1"
                        Style="{StaticResource PureCardRadioGroupListBox}">
                        <ListBoxItem Content="按月付费" />
                        <ListBoxItem Content="按年付费" />
                    </ListBox>
                </semi:StackPanel>
            </GroupBox>
            <GroupBox Padding="16" Header="Check group themes">
                <semi:Grid ColumnSpacing="24">
                    <semi:Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </semi:Grid.ColumnDefinitions>
                    <semi:StackPanel Spacing="8">
                        <TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="CheckGroupListBox" />
                        <ListBox SelectionMode="Multiple" Style="{StaticResource CheckGroupListBox}">
                            <ListBoxItem Content="设计" IsSelected="True" />
                            <ListBoxItem Content="开发" />
                            <ListBoxItem Content="测试" IsSelected="True" />
                        </ListBox>
                    </semi:StackPanel>
                    <semi:StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="CardCheckGroupListBox" />
                        <ListBox SelectionMode="Multiple" Style="{StaticResource CardCheckGroupListBox}">
                            <ListBoxItem Content="邮件通知" IsSelected="True" />
                            <ListBoxItem Content="短信通知" />
                            <ListBoxItem Content="站内通知" IsSelected="True" />
                        </ListBox>
                    </semi:StackPanel>
                </semi:Grid>
            </GroupBox>
        </semi:StackPanel>
    </ScrollViewer>
</UserControl>
