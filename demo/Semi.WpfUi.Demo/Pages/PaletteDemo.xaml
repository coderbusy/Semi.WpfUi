<UserControl x:Class="Semi.WpfUi.Demo.Pages.PaletteDemo" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32" MaxWidth="860">
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader3}" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Palette" />
            <TextBlock Margin="0,8,0,28" Foreground="{DynamicResource SemiColorText1}" Text="Semantic palette resources. Switch the application theme from the sidebar to inspect their dynamic values." />
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader6}" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Brand &amp; functional colors" />
            <UniformGrid Margin="0,16,0,32" Columns="3">
                <Border Height="96" Margin="0,0,12,12" Padding="16" Background="{DynamicResource SemiColorPrimary}" CornerRadius="{DynamicResource SemiBorderRadiusMedium}"><StackPanel><TextBlock Foreground="White" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Primary" /><TextBlock Margin="0,6,0,0" Foreground="White" Opacity="0.8" Text="SemiColorPrimary" /></StackPanel></Border>
                <Border Height="96" Margin="0,0,12,12" Padding="16" Background="{DynamicResource SemiColorSuccess}" CornerRadius="{DynamicResource SemiBorderRadiusMedium}"><StackPanel><TextBlock Foreground="White" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Success" /><TextBlock Margin="0,6,0,0" Foreground="White" Opacity="0.8" Text="SemiColorSuccess" /></StackPanel></Border>
                <Border Height="96" Margin="0,0,12,12" Padding="16" Background="{DynamicResource SemiColorWarning}" CornerRadius="{DynamicResource SemiBorderRadiusMedium}"><StackPanel><TextBlock Foreground="White" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Warning" /><TextBlock Margin="0,6,0,0" Foreground="White" Opacity="0.8" Text="SemiColorWarning" /></StackPanel></Border>
                <Border Height="96" Margin="0,0,12,12" Padding="16" Background="{DynamicResource SemiColorDanger}" CornerRadius="{DynamicResource SemiBorderRadiusMedium}"><StackPanel><TextBlock Foreground="White" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Danger" /><TextBlock Margin="0,6,0,0" Foreground="White" Opacity="0.8" Text="SemiColorDanger" /></StackPanel></Border>
                <Border Height="96" Margin="0,0,12,12" Padding="16" Background="{DynamicResource SemiColorInformation}" CornerRadius="{DynamicResource SemiBorderRadiusMedium}"><StackPanel><TextBlock Foreground="White" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Information" /><TextBlock Margin="0,6,0,0" Foreground="White" Opacity="0.8" Text="SemiColorInformation" /></StackPanel></Border>
                <Border Height="96" Margin="0,0,12,12" Padding="16" Background="{DynamicResource SemiColorSecondary}" CornerRadius="{DynamicResource SemiBorderRadiusMedium}"><StackPanel><TextBlock Foreground="White" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Secondary" /><TextBlock Margin="0,6,0,0" Foreground="White" Opacity="0.8" Text="SemiColorSecondary" /></StackPanel></Border>
            </UniformGrid>
            <TextBlock FontSize="{DynamicResource SemiFontSizeHeader6}" FontWeight="{DynamicResource SemiFontWeightBold}" Text="Surface &amp; text" />
            <UniformGrid Margin="0,16,0,0" Columns="2">
                <Border Height="100" Margin="0,0,12,12" Padding="16" Background="{DynamicResource SemiColorBackground0}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="{DynamicResource SemiBorderRadiusMedium}"><StackPanel><TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="Background 0" /><TextBlock Margin="0,6,0,0" Foreground="{DynamicResource SemiColorText2}" Text="SemiColorBackground0" /></StackPanel></Border>
                <Border Height="100" Margin="0,0,12,12" Padding="16" Background="{DynamicResource SemiColorBackground1}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="{DynamicResource SemiBorderRadiusMedium}"><StackPanel><TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="Background 1" /><TextBlock Margin="0,6,0,0" Foreground="{DynamicResource SemiColorText2}" Text="SemiColorBackground1" /></StackPanel></Border>
                <Border Height="100" Margin="0,0,12,12" Padding="16" Background="{DynamicResource SemiColorFill0}" CornerRadius="{DynamicResource SemiBorderRadiusMedium}"><StackPanel><TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="Fill 0" /><TextBlock Margin="0,6,0,0" Foreground="{DynamicResource SemiColorText2}" Text="SemiColorFill0" /></StackPanel></Border>
                <Border Height="100" Margin="0,0,12,12" Padding="16" Background="{DynamicResource SemiColorFill1}" CornerRadius="{DynamicResource SemiBorderRadiusMedium}"><StackPanel><TextBlock FontWeight="{DynamicResource SemiFontWeightBold}" Text="Fill 1" /><TextBlock Margin="0,6,0,0" Foreground="{DynamicResource SemiColorText2}" Text="SemiColorFill1" /></StackPanel></Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
