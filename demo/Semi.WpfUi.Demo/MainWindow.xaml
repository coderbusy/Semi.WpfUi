<Window
    x:Class="Semi.WpfUi.Demo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:att="clr-namespace:Semi.WpfUi.Attached;assembly=Semi.WpfUi"
    xmlns:semi="clr-namespace:Semi.WpfUi;assembly=Semi.WpfUi"
    Title="Semi.WpfUi Demo"
    Width="900"
    Height="680"
    Background="{DynamicResource SemiColorBackground0}"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Title bar  -->
        <Border
            Grid.Row="0"
            Padding="24,16"
            Background="{DynamicResource SemiColorBackground0}"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        FontSize="{DynamicResource SemiFontSizeHeader5}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="Semi.WpfUi" />
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        Foreground="{DynamicResource SemiColorText2}"
                        Text=" — WPF Semi Design Theme" />
                </StackPanel>
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource SemiFontSizeRegular}"
                        Foreground="{DynamicResource SemiColorText2}"
                        Text="Theme:" />
                    <Button
                        x:Name="LightThemeButton"
                        Margin="8,0,0,0"
                        Click="OnLightThemeClick"
                        Content="Light" />
                    <Button
                        x:Name="DarkThemeButton"
                        Margin="8,0,0,0"
                        Click="OnDarkThemeClick"
                        Content="Dark" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Main content  -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <TextBlock
                    att:Classes.Danger="{Binding ElementName=IsDangerCheckBox, Path=IsChecked}"
                    Style="{StaticResource TitleTextBlock}"
                    Text="TestTextBlock" />
                <CheckBox Name="IsDangerCheckBox">IsDanger</CheckBox>
                <!--  Buttons  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="Button" />
                    <WrapPanel>
                        <Button Margin="0,0,8,8" Content="Default" />
                        <Button
                            Margin="0,0,8,8"
                            Content="Primary"
                            Style="{StaticResource SemiButtonPrimary}" />
                        <Button
                            Margin="0,0,8,8"
                            Content="Danger"
                            Style="{StaticResource SemiButtonDanger}" />
                        <Button
                            Margin="0,0,8,8"
                            Content="Light"
                            Style="{StaticResource SemiButtonLight}" />
                        <Button
                            Margin="0,0,8,8"
                            Content="Disabled"
                            IsEnabled="False" />
                        <Button
                            Margin="0,0,8,8"
                            Content="Disabled Primary"
                            IsEnabled="False"
                            Style="{StaticResource SemiButtonPrimary}" />
                    </WrapPanel>
                </StackPanel>

                <!--  TextBox  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="TextBox" />
                    <WrapPanel>
                        <TextBox
                            Width="200"
                            Margin="0,0,8,8"
                            Text="Default text" />
                        <TextBox
                            Width="200"
                            Margin="0,0,8,8"
                            IsReadOnly="True"
                            Text="Read only" />
                        <TextBox
                            Width="200"
                            Margin="0,0,8,8"
                            IsEnabled="False"
                            Text="Disabled" />
                    </WrapPanel>
                </StackPanel>

                <!--  CheckBox  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="CheckBox" />
                    <WrapPanel>
                        <CheckBox Margin="0,0,16,8" Content="Unchecked" />
                        <CheckBox
                            Margin="0,0,16,8"
                            Content="Checked"
                            IsChecked="True" />
                        <CheckBox
                            Margin="0,0,16,8"
                            Content="Indeterminate"
                            IsChecked="{x:Null}"
                            IsThreeState="True" />
                        <CheckBox
                            Margin="0,0,16,8"
                            Content="Disabled"
                            IsEnabled="False" />
                        <CheckBox
                            Margin="0,0,16,8"
                            Content="Disabled Checked"
                            IsChecked="True"
                            IsEnabled="False" />
                    </WrapPanel>
                </StackPanel>

                <!--  RadioButton  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="RadioButton" />
                    <WrapPanel>
                        <RadioButton
                            Margin="0,0,16,8"
                            Content="Option A"
                            GroupName="demo"
                            IsChecked="True" />
                        <RadioButton
                            Margin="0,0,16,8"
                            Content="Option B"
                            GroupName="demo" />
                        <RadioButton
                            Margin="0,0,16,8"
                            Content="Option C"
                            GroupName="demo" />
                        <RadioButton
                            Margin="0,0,16,8"
                            Content="Disabled"
                            GroupName="demo2"
                            IsEnabled="False" />
                    </WrapPanel>
                </StackPanel>

                <!--  ComboBox  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="ComboBox" />
                    <WrapPanel>
                        <ComboBox
                            Width="160"
                            Margin="0,0,8,8"
                            SelectedIndex="0">
                            <ComboBoxItem Content="Option 1" />
                            <ComboBoxItem Content="Option 2" />
                            <ComboBoxItem Content="Option 3" />
                        </ComboBox>
                        <ComboBox
                            Width="160"
                            Margin="0,0,8,8"
                            IsEnabled="False"
                            SelectedIndex="0">
                            <ComboBoxItem Content="Disabled" />
                        </ComboBox>
                    </WrapPanel>
                </StackPanel>

                <!--  ToggleButton  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="ToggleButton" />
                    <WrapPanel>
                        <ToggleButton Margin="0,0,8,8" Content="Toggle Off" />
                        <ToggleButton
                            Margin="0,0,8,8"
                            Content="Toggle On"
                            IsChecked="True" />
                        <ToggleButton
                            Margin="0,0,8,8"
                            Content="Disabled"
                            IsEnabled="False" />
                    </WrapPanel>
                </StackPanel>

                <!--  ProgressBar  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="ProgressBar" />
                    <StackPanel MaxWidth="400" HorizontalAlignment="Left">
                        <ProgressBar
                            Margin="0,0,0,8"
                            Maximum="100"
                            Value="30" />
                        <ProgressBar
                            Margin="0,0,0,8"
                            Maximum="100"
                            Value="60" />
                        <ProgressBar Maximum="100" Value="90" />
                    </StackPanel>
                </StackPanel>

                <!--  Slider  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="Slider" />
                    <StackPanel MaxWidth="400" HorizontalAlignment="Left">
                        <Slider
                            Margin="0,0,0,8"
                            Maximum="100"
                            Value="40" />
                        <Slider
                            Margin="0,0,0,8"
                            Maximum="100"
                            Value="70" />
                        <Slider
                            IsEnabled="False"
                            Maximum="100"
                            Value="20" />
                    </StackPanel>
                </StackPanel>

                <!--  ListBox  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="ListBox" />
                    <ListBox
                        Width="200"
                        Height="120"
                        HorizontalAlignment="Left"
                        SelectedIndex="1">
                        <ListBoxItem Content="Item One" />
                        <ListBoxItem Content="Item Two" />
                        <ListBoxItem Content="Item Three" />
                        <ListBoxItem Content="Item Four" />
                    </ListBox>
                </StackPanel>

                <!--  TabControl  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="TabControl" />
                    <TabControl MaxWidth="500" HorizontalAlignment="Left">
                        <TabItem Header="Overview">
                            <TextBlock
                                Padding="0,8"
                                Foreground="{DynamicResource SemiColorText1}"
                                Text="This is the overview tab content." />
                        </TabItem>
                        <TabItem Header="Details">
                            <TextBlock
                                Padding="0,8"
                                Foreground="{DynamicResource SemiColorText1}"
                                Text="This is the details tab content." />
                        </TabItem>
                        <TabItem Header="Settings">
                            <TextBlock
                                Padding="0,8"
                                Foreground="{DynamicResource SemiColorText1}"
                                Text="This is the settings tab content." />
                        </TabItem>
                    </TabControl>
                </StackPanel>

                <!--  Typography  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="Typography" />
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{DynamicResource SemiFontSizeHeader1}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="Header 1 — 32px" />
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{DynamicResource SemiFontSizeHeader3}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="Header 3 — 24px" />
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{DynamicResource SemiFontSizeRegular}"
                        Foreground="{DynamicResource SemiColorText1}"
                        Text="Regular — 14px" />
                    <TextBlock
                        FontSize="{DynamicResource SemiFontSizeSmall}"
                        Foreground="{DynamicResource SemiColorText2}"
                        Text="Small — 12px" />
                </StackPanel>

                <!--  Colors  -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource SemiFontSizeHeader6}"
                        FontWeight="{DynamicResource SemiFontWeightBold}"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="Color Palette" />
                    <WrapPanel>
                        <Border
                            Width="80"
                            Height="40"
                            Margin="0,0,8,8"
                            Background="{DynamicResource SemiColorPrimary}"
                            CornerRadius="{DynamicResource SemiBorderRadiusSmall}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="White"
                                Text="Primary" />
                        </Border>
                        <Border
                            Width="80"
                            Height="40"
                            Margin="0,0,8,8"
                            Background="{DynamicResource SemiColorSuccess}"
                            CornerRadius="{DynamicResource SemiBorderRadiusSmall}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="White"
                                Text="Success" />
                        </Border>
                        <Border
                            Width="80"
                            Height="40"
                            Margin="0,0,8,8"
                            Background="{DynamicResource SemiColorWarning}"
                            CornerRadius="{DynamicResource SemiBorderRadiusSmall}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="White"
                                Text="Warning" />
                        </Border>
                        <Border
                            Width="80"
                            Height="40"
                            Margin="0,0,8,8"
                            Background="{DynamicResource SemiColorDanger}"
                            CornerRadius="{DynamicResource SemiBorderRadiusSmall}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="White"
                                Text="Danger" />
                        </Border>
                        <Border
                            Width="80"
                            Height="40"
                            Margin="0,0,8,8"
                            Background="{DynamicResource SemiColorBackground3}"
                            BorderBrush="{DynamicResource SemiColorBorder}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource SemiBorderRadiusSmall}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource SemiColorText0}"
                                Text="Bg3" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
