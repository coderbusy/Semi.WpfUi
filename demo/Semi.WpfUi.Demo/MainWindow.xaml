<Window
    x:Class="Semi.WpfUi.Demo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Semi.WpfUi Demo"
    Width="1180"
    Height="760"
    MinWidth="900"
    MinHeight="600"
    Background="{DynamicResource SemiColorBackground0}"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="NavigationItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="6,1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="{DynamicResource SemiBorderRadiusSmall}">
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SemiColorPrimaryLight}" />
                                <Setter Property="Foreground" Value="{DynamicResource SemiColorPrimary}" />
                                <Setter Property="FontWeight" Value="{DynamicResource SemiFontWeightBold}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SemiColorFill0}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource SemiColorBackground1}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock FontSize="{DynamicResource SemiFontSizeHeader5}" FontWeight="{DynamicResource SemiFontWeightBold}" Foreground="{DynamicResource SemiColorText0}" Text="Semi WPF" />
                    <TextBlock Margin="0,4,0,16" Foreground="{DynamicResource SemiColorText2}" Text="Semi Design theme showcase" />
                </StackPanel>
                <TextBox x:Name="SearchBox" Grid.Row="1" Padding="10,7" TextChanged="OnSearchTextChanged" ToolTip="Search demos or sections" />
                <ListBox x:Name="NavigationList" Grid.Row="2" Margin="-6,16,-6,12" ItemsSource="{Binding NavigationView}" SelectionChanged="OnNavigationSelectionChanged" ItemContainerStyle="{StaticResource NavigationItemStyle}" BorderThickness="0" Background="Transparent">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="12,12,12,4" FontSize="{DynamicResource SemiFontSizeSmall}" FontWeight="{DynamicResource SemiFontWeightBold}" Foreground="{DynamicResource SemiColorText2}" Text="{Binding Name}" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="3">
                    <Separator Margin="0,0,0,12" />
                    <TextBlock Foreground="{DynamicResource SemiColorText2}" FontSize="{DynamicResource SemiFontSizeSmall}" Text="Appearance" />
                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <Button Padding="12,5" Click="OnLightThemeClick" Content="Light" />
                        <Button Margin="8,0,0,0" Padding="12,5" Click="OnDarkThemeClick" Content="Dark" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Padding="32,20" Background="{DynamicResource SemiColorBackground0}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="{DynamicResource SemiFontSizeHeader5}" FontWeight="{DynamicResource SemiFontWeightBold}" Foreground="{DynamicResource SemiColorText0}" Text="Semi.WpfUi" />
                    <TextBlock Margin="10,0" VerticalAlignment="Center" Foreground="{DynamicResource SemiColorText2}" Text="/" />
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource SemiColorText1}" Text="{Binding SelectedPageTitle}" />
                </StackPanel>
            </Border>
            <ContentControl Grid.Row="1" Content="{Binding SelectedPage}" />
        </Grid>
    </Grid>
</Window>
