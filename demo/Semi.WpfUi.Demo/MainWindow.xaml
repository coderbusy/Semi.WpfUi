<Window x:Class="Semi.WpfUi.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:semi="clr-namespace:Semi.WpfUi;assembly=Semi.WpfUi"
        Title="Semi.WpfUi Demo"
        Width="900" Height="680"
        Background="{DynamicResource SemiColorBg0}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Padding="24,16"
                Background="{DynamicResource SemiColorBg0}"
                BorderBrush="{DynamicResource SemiColorBorder}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Semi.WpfUi"
                               FontSize="{DynamicResource SemiFontSizeHeader5}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}" />
                    <TextBlock Text=" — WPF Semi Design Theme"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               Foreground="{DynamicResource SemiColorText2}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Theme:" VerticalAlignment="Center"
                               Foreground="{DynamicResource SemiColorText2}"
                               FontSize="{DynamicResource SemiFontSizeRegular}" />
                    <Button x:Name="LightThemeButton" Content="Light"
                            Margin="8,0,0,0"
                            Click="OnLightThemeClick" />
                    <Button x:Name="DarkThemeButton" Content="Dark"
                            Margin="8,0,0,0"
                            Click="OnDarkThemeClick" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Buttons -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="Button"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,12" />
                    <WrapPanel>
                        <Button Content="Default" Margin="0,0,8,8" />
                        <Button Style="{StaticResource SemiButtonPrimary}" Content="Primary" Margin="0,0,8,8" />
                        <Button Style="{StaticResource SemiButtonDanger}" Content="Danger" Margin="0,0,8,8" />
                        <Button Style="{StaticResource SemiButtonLight}" Content="Light" Margin="0,0,8,8" />
                        <Button Content="Disabled" IsEnabled="False" Margin="0,0,8,8" />
                        <Button Style="{StaticResource SemiButtonPrimary}" Content="Disabled Primary" IsEnabled="False" Margin="0,0,8,8" />
                    </WrapPanel>
                </StackPanel>

                <!-- TextBox -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="TextBox"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,12" />
                    <WrapPanel>
                        <TextBox Width="200" Text="Default text" Margin="0,0,8,8" />
                        <TextBox Width="200" Text="Read only" IsReadOnly="True" Margin="0,0,8,8" />
                        <TextBox Width="200" Text="Disabled" IsEnabled="False" Margin="0,0,8,8" />
                    </WrapPanel>
                </StackPanel>

                <!-- CheckBox -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="CheckBox"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,12" />
                    <WrapPanel>
                        <CheckBox Content="Unchecked" Margin="0,0,16,8" />
                        <CheckBox Content="Checked" IsChecked="True" Margin="0,0,16,8" />
                        <CheckBox Content="Indeterminate" IsChecked="{x:Null}" IsThreeState="True" Margin="0,0,16,8" />
                        <CheckBox Content="Disabled" IsEnabled="False" Margin="0,0,16,8" />
                        <CheckBox Content="Disabled Checked" IsChecked="True" IsEnabled="False" Margin="0,0,16,8" />
                    </WrapPanel>
                </StackPanel>

                <!-- RadioButton -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="RadioButton"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,12" />
                    <WrapPanel>
                        <RadioButton Content="Option A" GroupName="demo" IsChecked="True" Margin="0,0,16,8" />
                        <RadioButton Content="Option B" GroupName="demo" Margin="0,0,16,8" />
                        <RadioButton Content="Option C" GroupName="demo" Margin="0,0,16,8" />
                        <RadioButton Content="Disabled" GroupName="demo2" IsEnabled="False" Margin="0,0,16,8" />
                    </WrapPanel>
                </StackPanel>

                <!-- ComboBox -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="ComboBox"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,12" />
                    <WrapPanel>
                        <ComboBox Width="160" SelectedIndex="0" Margin="0,0,8,8">
                            <ComboBoxItem Content="Option 1" />
                            <ComboBoxItem Content="Option 2" />
                            <ComboBoxItem Content="Option 3" />
                        </ComboBox>
                        <ComboBox Width="160" IsEnabled="False" SelectedIndex="0" Margin="0,0,8,8">
                            <ComboBoxItem Content="Disabled" />
                        </ComboBox>
                    </WrapPanel>
                </StackPanel>

                <!-- ToggleButton -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="ToggleButton"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,12" />
                    <WrapPanel>
                        <ToggleButton Content="Toggle Off" Margin="0,0,8,8" />
                        <ToggleButton Content="Toggle On" IsChecked="True" Margin="0,0,8,8" />
                        <ToggleButton Content="Disabled" IsEnabled="False" Margin="0,0,8,8" />
                    </WrapPanel>
                </StackPanel>

                <!-- ProgressBar -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="ProgressBar"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,12" />
                    <StackPanel MaxWidth="400" HorizontalAlignment="Left">
                        <ProgressBar Value="30" Maximum="100" Margin="0,0,0,8" />
                        <ProgressBar Value="60" Maximum="100" Margin="0,0,0,8" />
                        <ProgressBar Value="90" Maximum="100" />
                    </StackPanel>
                </StackPanel>

                <!-- Slider -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="Slider"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,12" />
                    <StackPanel MaxWidth="400" HorizontalAlignment="Left">
                        <Slider Value="40" Maximum="100" Margin="0,0,0,8" />
                        <Slider Value="70" Maximum="100" Margin="0,0,0,8" />
                        <Slider Value="20" Maximum="100" IsEnabled="False" />
                    </StackPanel>
                </StackPanel>

                <!-- ListBox -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="ListBox"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,12" />
                    <ListBox Width="200" Height="120" HorizontalAlignment="Left" SelectedIndex="1">
                        <ListBoxItem Content="Item One" />
                        <ListBoxItem Content="Item Two" />
                        <ListBoxItem Content="Item Three" />
                        <ListBoxItem Content="Item Four" />
                    </ListBox>
                </StackPanel>

                <!-- TabControl -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="TabControl"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,12" />
                    <TabControl MaxWidth="500" HorizontalAlignment="Left">
                        <TabItem Header="Overview">
                            <TextBlock Text="This is the overview tab content."
                                       Foreground="{DynamicResource SemiColorText1}"
                                       Padding="0,8" />
                        </TabItem>
                        <TabItem Header="Details">
                            <TextBlock Text="This is the details tab content."
                                       Foreground="{DynamicResource SemiColorText1}"
                                       Padding="0,8" />
                        </TabItem>
                        <TabItem Header="Settings">
                            <TextBlock Text="This is the settings tab content."
                                       Foreground="{DynamicResource SemiColorText1}"
                                       Padding="0,8" />
                        </TabItem>
                    </TabControl>
                </StackPanel>

                <!-- Typography -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="Typography"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Header 1 — 32px"
                               FontSize="{DynamicResource SemiFontSizeHeader1}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Header 3 — 24px"
                               FontSize="{DynamicResource SemiFontSizeHeader3}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Regular — 14px"
                               FontSize="{DynamicResource SemiFontSizeRegular}"
                               Foreground="{DynamicResource SemiColorText1}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Small — 12px"
                               FontSize="{DynamicResource SemiFontSizeSmall}"
                               Foreground="{DynamicResource SemiColorText2}" />
                </StackPanel>

                <!-- Colors -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="Color Palette"
                               FontSize="{DynamicResource SemiFontSizeHeader6}"
                               FontWeight="{DynamicResource SemiFontWeightBold}"
                               Foreground="{DynamicResource SemiColorText0}"
                               Margin="0,0,0,12" />
                    <WrapPanel>
                        <Border Width="80" Height="40" Background="{DynamicResource SemiColorPrimary}"
                                CornerRadius="{DynamicResource SemiBorderRadiusSmall}"
                                Margin="0,0,8,8">
                            <TextBlock Text="Primary" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                        </Border>
                        <Border Width="80" Height="40" Background="{DynamicResource SemiColorSuccess}"
                                CornerRadius="{DynamicResource SemiBorderRadiusSmall}"
                                Margin="0,0,8,8">
                            <TextBlock Text="Success" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                        </Border>
                        <Border Width="80" Height="40" Background="{DynamicResource SemiColorWarning}"
                                CornerRadius="{DynamicResource SemiBorderRadiusSmall}"
                                Margin="0,0,8,8">
                            <TextBlock Text="Warning" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                        </Border>
                        <Border Width="80" Height="40" Background="{DynamicResource SemiColorDanger}"
                                CornerRadius="{DynamicResource SemiBorderRadiusSmall}"
                                Margin="0,0,8,8">
                            <TextBlock Text="Danger" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                        </Border>
                        <Border Width="80" Height="40" Background="{DynamicResource SemiColorBg3}"
                                BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1"
                                CornerRadius="{DynamicResource SemiBorderRadiusSmall}"
                                Margin="0,0,8,8">
                            <TextBlock Text="Bg3" Foreground="{DynamicResource SemiColorText0}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
