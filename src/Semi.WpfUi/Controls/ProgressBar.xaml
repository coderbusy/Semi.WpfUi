<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:attached="clr-namespace:Semi.WpfUi.Attached">
    <ControlTemplate x:Key="SemiProgressBarTemplate" TargetType="ProgressBar">
        <ControlTemplate.Resources>
            <Storyboard x:Key="IndeterminateStoryboard" RepeatBehavior="Forever">
                <PointAnimation
                    Storyboard.TargetName="IndeterminateIndicator"
                    Storyboard.TargetProperty="RenderTransformOrigin"
                    From="-0.5,0.5"
                    To="1.5,0.5"
                    Duration="0:0:1.2" />
            </Storyboard>
        </ControlTemplate.Resources>
        <Border
            x:Name="TemplateRoot"
            Background="{TemplateBinding Background}"
            CornerRadius="{DynamicResource ProgressBarCornerRadius}"
            SnapsToDevicePixels="True">
            <Grid x:Name="PART_Track" ClipToBounds="True">
                <Border
                    x:Name="PART_Indicator"
                    HorizontalAlignment="Left"
                    Background="{TemplateBinding Foreground}"
                    CornerRadius="{DynamicResource ProgressBarCornerRadius}" />
                <Border
                    x:Name="IndeterminateIndicator"
                    HorizontalAlignment="Stretch"
                    Background="{TemplateBinding Foreground}"
                    CornerRadius="{DynamicResource ProgressBarCornerRadius}"
                    RenderTransformOrigin="-0.5,0.5"
                    Visibility="Collapsed">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.25" />
                    </Border.RenderTransform>
                </Border>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsIndeterminate" Value="True">
                <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IndeterminateIndicator" Property="Visibility" Value="Visible" />
                <Trigger.EnterActions>
                    <BeginStoryboard x:Name="IndeterminateAnimation" Storyboard="{StaticResource IndeterminateStoryboard}" />
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="IndeterminateAnimation" />
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter TargetName="TemplateRoot" Property="LayoutTransform">
                    <Setter.Value>
                        <RotateTransform Angle="-90" />
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource ProgressBarDisabledIndicatorBrush}" />
                <Setter Property="Background" Value="{DynamicResource ProgressBarDisabledTrackBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="{x:Type ProgressBar}" TargetType="ProgressBar">
        <Setter Property="Height" Value="{DynamicResource ProgressBarHeight}" />
        <Setter Property="MinWidth" Value="200" />
        <Setter Property="Foreground" Value="{DynamicResource ProgressBarIndicatorBrush}" />
        <Setter Property="Background" Value="{DynamicResource ProgressBarTrackBrush}" />
        <Setter Property="Template" Value="{StaticResource SemiProgressBarTemplate}" />
        <Style.Triggers>
            <Trigger Property="attached:Classes.Success" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ProgressBarSuccessIndicatorBrush}" />
            </Trigger>
            <Trigger Property="attached:Classes.Warning" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ProgressBarWarningIndicatorBrush}" />
            </Trigger>
            <Trigger Property="attached:Classes.Danger" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ProgressBarDangerIndicatorBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
