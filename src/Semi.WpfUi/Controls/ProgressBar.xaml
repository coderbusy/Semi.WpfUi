<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:attached="clr-namespace:Semi.WpfUi.Attached">
    <ControlTemplate x:Key="SemiProgressBarTemplate" TargetType="ProgressBar">
        <Border
            x:Name="TrackBorder"
            Height="{TemplateBinding Height}"
            Background="{TemplateBinding Background}"
            CornerRadius="{DynamicResource ProgressBarCornerRadius}"
            SnapsToDevicePixels="True">
            <Track
                x:Name="PART_Track"
                IsDirectionReversed="False"
                Maximum="{TemplateBinding Maximum}"
                Minimum="{TemplateBinding Minimum}"
                Orientation="{TemplateBinding Orientation}"
                Value="{TemplateBinding Value}">
                <Track.DecreaseRepeatButton>
                    <RepeatButton
                        Background="Transparent"
                        BorderThickness="0"
                        IsHitTestVisible="False"
                        Focusable="False"
                        Template="{StaticResource ProgressBarTrackButtonTemplate}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb
                        x:Name="PART_Indicator"
                        Background="{TemplateBinding Foreground}"
                        Focusable="False"
                        Template="{StaticResource ProgressBarIndicatorTemplate}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton
                        Background="Transparent"
                        BorderThickness="0"
                        IsHitTestVisible="False"
                        Focusable="False"
                        Template="{StaticResource ProgressBarTrackButtonTemplate}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsIndeterminate" Value="True">
                <Setter TargetName="PART_Indicator" Property="Width" Value="96" />
                <Setter TargetName="PART_Indicator" Property="HorizontalAlignment" Value="Left" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource ProgressBarDisabledIndicatorBrush}" />
                <Setter Property="Background" Value="{DynamicResource ProgressBarDisabledTrackBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ProgressBarTrackButtonTemplate" TargetType="RepeatButton">
        <Border Background="{TemplateBinding Background}" />
    </ControlTemplate>

    <ControlTemplate x:Key="ProgressBarIndicatorTemplate" TargetType="Thumb">
        <Border
            Background="{TemplateBinding Background}"
            CornerRadius="{DynamicResource ProgressBarCornerRadius}" />
    </ControlTemplate>

    <Style x:Key="{x:Type ProgressBar}" TargetType="ProgressBar">
        <Setter Property="Height" Value="{DynamicResource ProgressBarHeight}" />
        <Setter Property="MinWidth" Value="200" />
        <Setter Property="Foreground" Value="{DynamicResource ProgressBarIndicatorBrush}" />
        <Setter Property="Background" Value="{DynamicResource ProgressBarTrackBrush}" />
        <Setter Property="Template" Value="{StaticResource SemiProgressBarTemplate}" />
        <Style.Triggers>
            <Trigger Property="attached:Classes.Success" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ProgressBarSuccessIndicatorBrush}" />
            </Trigger>
            <Trigger Property="attached:Classes.Warning" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ProgressBarWarningIndicatorBrush}" />
            </Trigger>
            <Trigger Property="attached:Classes.Danger" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource ProgressBarDangerIndicatorBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
