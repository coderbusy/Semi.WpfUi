<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:attached="clr-namespace:Semi.WpfUi.Attached">
    <Style x:Key="{x:Type TextBlock}" TargetType="TextBlock">
        <Style.Triggers>
            <Trigger Property="attached:Classes.Secondary" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextBlockSecondaryForeground}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>