<ResourceDictionary
    x:Class="Semi.WpfUi.Tokens.Variables"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!--  Sizing  -->
    <sys:Double x:Key="SemiHeightControlSmall">24</sys:Double>
    <!--  表单项高度 - 小尺寸  -->
    <sys:Double x:Key="SemiHeightControlDefault">32</sys:Double>
    <!--  表单项高度 - 默认尺寸  -->
    <sys:Double x:Key="SemiHeightControlLarge">40</sys:Double>
    <!--  表单项高度 - 大尺寸  -->
    <sys:Double x:Key="SemiWidthIconExtraSmall">8</sys:Double>
    <!--  图标尺寸 - 超小  -->
    <sys:Double x:Key="SemiWidthIconSmall">12</sys:Double>
    <!--  图标尺寸 - 小  -->
    <sys:Double x:Key="SemiWidthIconMedium">16</sys:Double>
    <!--  图标尺寸 - 中  -->
    <sys:Double x:Key="SemiWidthIconLarge">20</sys:Double>
    <!--  图标尺寸 - 大  -->
    <sys:Double x:Key="SemiWidthIconExtraLarge">24</sys:Double>
    <!--  图标尺寸 - 超大  -->

    <!--  Border  -->
    <sys:Double x:Key="SemiBorderSpacing">0</sys:Double>
    <!--  描边间距 - 零  -->
    <sys:Double x:Key="SemiBorderSpacingControl">1</sys:Double>
    <!--  描边间距 - 默认状态  -->
    <sys:Double x:Key="SemiBorderSpacingControlFocus">1</sys:Double>
    <!--  描边间距 - focus 状态  -->
    <Thickness x:Key="SemiBorderThickness">0</Thickness>
    <!--  描边宽度 - 零  -->
    <Thickness x:Key="SemiBorderThicknessControl">1</Thickness>
    <!--  描边宽度 - 默认状态  -->
    <Thickness x:Key="SemiBorderThicknessControlFocus">1</Thickness>
    <!--  描边宽度 - focus 状态  -->
    <CornerRadius x:Key="SemiBorderRadiusExtraSmall">3</CornerRadius>
    <!--  圆角 - 超小  -->
    <sys:Double x:Key="SemiBorderRadiusSpacingSmall">3</sys:Double>
    <!--  半径 - 小  -->
    <sys:Double x:Key="SemiBorderRadiusSpacingMedium">6</sys:Double>
    <!--  半径 - 中  -->
    <sys:Double x:Key="SemiBorderRadiusSpacingLarge">12</sys:Double>
    <!--  半径 - 大  -->
    <sys:Double x:Key="SemiBorderRadiusSpacingFull">9999</sys:Double>
    <!--  半径 - 全圆  -->
    <CornerRadius x:Key="SemiBorderRadiusSmall">3</CornerRadius>
    <!--  圆角 - 小  -->
    <CornerRadius x:Key="SemiBorderRadiusMedium">6</CornerRadius>
    <!--  圆角 - 中  -->
    <CornerRadius x:Key="SemiBorderRadiusLarge">12</CornerRadius>
    <!--  圆角 - 大  -->
    <CornerRadius x:Key="SemiBorderRadiusFull">9999</CornerRadius>
    <!--  圆角 - 全圆  -->

    <!--  Spacing  -->
    <sys:Double x:Key="SemiSpacingNone">0</sys:Double>
    <!--  间距 - 零  -->
    <sys:Double x:Key="SemiSpacingSuperTight">2</sys:Double>
    <!--  间距 - 极紧凑  -->
    <sys:Double x:Key="SemiSpacingExtraTight">4</sys:Double>
    <!--  间距 - 超紧凑  -->
    <sys:Double x:Key="SemiSpacingTight">8</sys:Double>
    <!--  间距 - 紧凑  -->
    <sys:Double x:Key="SemiSpacingBaseTight">12</sys:Double>
    <!--  间距 - 偏紧凑  -->
    <sys:Double x:Key="SemiSpacingBase">16</sys:Double>
    <!--  间距 - 默认  -->
    <sys:Double x:Key="SemiSpacingBaseLoose">20</sys:Double>
    <!--  间距 - 偏宽松  -->
    <sys:Double x:Key="SemiSpacingLoose">24</sys:Double>
    <!--  间距 - 宽松  -->
    <sys:Double x:Key="SemiSpacingExtraLoose">32</sys:Double>
    <!--  间距 - 超宽松  -->
    <sys:Double x:Key="SemiSpacingSuperLoose">40</sys:Double>
    <!--  间距 - 极宽松  -->

    <!--  Thickness  -->
    <Thickness x:Key="SemiThicknessNone">0</Thickness>
    <!--  宽度 - 零  -->
    <Thickness x:Key="SemiThicknessSuperTight">2</Thickness>
    <!--  宽度 - 极紧凑  -->
    <Thickness x:Key="SemiThicknessExtraTight">4</Thickness>
    <!--  宽度 - 超紧凑  -->
    <Thickness x:Key="SemiThicknessTight">8</Thickness>
    <!--  宽度 - 紧凑  -->
    <Thickness x:Key="SemiThicknessBaseTight">12</Thickness>
    <!--  宽度 - 偏紧凑  -->
    <Thickness x:Key="SemiThicknessBase">16</Thickness>
    <!--  宽度 - 默认  -->
    <Thickness x:Key="SemiThicknessBaseLoose">20</Thickness>
    <!--  宽度 - 偏宽松  -->
    <Thickness x:Key="SemiThicknessLoose">24</Thickness>
    <!--  宽度 - 宽松  -->
    <Thickness x:Key="SemiThicknessExtraLoose">32</Thickness>
    <!--  宽度 - 超宽松  -->
    <Thickness x:Key="SemiThicknessSuperLoose">40</Thickness>
    <!--  宽度 - 极宽松  -->

    <!--  Font  -->
    <sys:Double x:Key="SemiFontSizeSmall">12</sys:Double>
    <!--  小文本字号  -->
    <sys:Double x:Key="SemiFontSizeRegular">14</sys:Double>
    <!--  常规文本字号  -->
    <sys:Double x:Key="SemiFontSizeHeader6">16</sys:Double>
    <!--  六级标题字号  -->
    <sys:Double x:Key="SemiFontSizeHeader5">18</sys:Double>
    <!--  五级标题字号  -->
    <sys:Double x:Key="SemiFontSizeHeader4">20</sys:Double>
    <!--  四级标题字号  -->
    <sys:Double x:Key="SemiFontSizeHeader3">24</sys:Double>
    <!--  三级标题字号  -->
    <sys:Double x:Key="SemiFontSizeHeader2">28</sys:Double>
    <!--  二级标题字号  -->
    <sys:Double x:Key="SemiFontSizeHeader1">32</sys:Double>
    <!--  一级标题字号  -->

    <!--<FontWeight x:Key="SemiFontWeightLight">200</FontWeight>-->
    <FontWeight x:Key="SemiFontWeightLight">ExtraLight</FontWeight>
    <!--  字重 - 轻  -->

    <!--<FontWeight x:Key="SemiFontWeightRegular">400</FontWeight>-->
    <FontWeight x:Key="SemiFontWeightRegular">Regular</FontWeight>
    <!--  字重 - 常规  -->

    <!--<FontWeight x:Key="SemiFontWeightBold">600</FontWeight>-->
    <FontWeight x:Key="SemiFontWeightBold">DemiBold</FontWeight>
    <!--  字重 - 粗  -->

    <FontFamily x:Key="SemiFontFamilyRegular">
        Inter, -apple-system, BlinkMacSystemFont, PingFang SC,
        Microsoft YaHei, Segoe UI, Hiragino Sans GB, Helvetica Neue,
        Helvetica, Arial, sans-serif
    </FontFamily>
</ResourceDictionary>
