<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Semi.WpfUi;component/Tokens/Palette/Light.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Semantic Color Tokens - Light Theme -->

    <!-- Background -->
    <SolidColorBrush x:Key="SemiColorBg0" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SemiColorBg1" Color="#F9F9F9" />
    <SolidColorBrush x:Key="SemiColorBg2" Color="#F2F2F2" />
    <SolidColorBrush x:Key="SemiColorBg3" Color="#E9E9E9" />
    <SolidColorBrush x:Key="SemiColorBg4" Color="#E1E1E1" />

    <!-- Text -->
    <SolidColorBrush x:Key="SemiColorText0" Color="#1C1F23" />
    <SolidColorBrush x:Key="SemiColorText1" Color="#2E3238" />
    <SolidColorBrush x:Key="SemiColorText2" Color="#41464C" />
    <SolidColorBrush x:Key="SemiColorText3" Color="#6B7075" />

    <!-- Border -->
    <SolidColorBrush x:Key="SemiColorBorder" Color="#E6E8EA" />
    <SolidColorBrush x:Key="SemiColorBorderHover" Color="#A7ABB0" />
    <SolidColorBrush x:Key="SemiColorBorderFocus" Color="#0064FA" />
    <SolidColorBrush x:Key="SemiColorBorderDisabled" Color="#E6E8EA" />

    <!-- Primary (Blue) -->
    <SolidColorBrush x:Key="SemiColorPrimary" Color="#0064FA" />
    <SolidColorBrush x:Key="SemiColorPrimaryHover" Color="#3295FB" />
    <SolidColorBrush x:Key="SemiColorPrimaryActive" Color="#0062D6" />
    <SolidColorBrush x:Key="SemiColorPrimaryDisabled" Color="#CBE7FE" />
    <SolidColorBrush x:Key="SemiColorPrimaryLight" Color="#EAF5FF" />
    <SolidColorBrush x:Key="SemiColorPrimaryLightHover" Color="#CBE7FE" />
    <SolidColorBrush x:Key="SemiColorPrimaryLightActive" Color="#98CDFD" />

    <!-- Success (Green) -->
    <SolidColorBrush x:Key="SemiColorSuccess" Color="#3BB346" />
    <SolidColorBrush x:Key="SemiColorSuccessHover" Color="#5AC262" />
    <SolidColorBrush x:Key="SemiColorSuccessActive" Color="#30953B" />
    <SolidColorBrush x:Key="SemiColorSuccessDisabled" Color="#D0F0D1" />
    <SolidColorBrush x:Key="SemiColorSuccessLight" Color="#ECF7EC" />

    <!-- Warning (Orange) -->
    <SolidColorBrush x:Key="SemiColorWarning" Color="#FC8800" />
    <SolidColorBrush x:Key="SemiColorWarningHover" Color="#FDA633" />
    <SolidColorBrush x:Key="SemiColorWarningActive" Color="#D26700" />
    <SolidColorBrush x:Key="SemiColorWarningLight" Color="#FFF8EA" />

    <!-- Danger (Red) -->
    <SolidColorBrush x:Key="SemiColorDanger" Color="#F93920" />
    <SolidColorBrush x:Key="SemiColorDangerHover" Color="#FA664C" />
    <SolidColorBrush x:Key="SemiColorDangerActive" Color="#D52515" />
    <SolidColorBrush x:Key="SemiColorDangerDisabled" Color="#FEDDD2" />
    <SolidColorBrush x:Key="SemiColorDangerLight" Color="#FEF2ED" />
    <SolidColorBrush x:Key="SemiColorDangerLightHover" Color="#FEDDD2" />
    <SolidColorBrush x:Key="SemiColorDangerLightActive" Color="#FDB7A5" />

    <!-- Focus ring -->
    <SolidColorBrush x:Key="SemiColorFocus" Color="#0064FA" />

    <!-- Disabled -->
    <SolidColorBrush x:Key="SemiColorDisabled" Color="#C6CACD" />
    <SolidColorBrush x:Key="SemiColorDisabledBg" Color="#F9F9F9" />
    <SolidColorBrush x:Key="SemiColorDisabledText" Color="#C6CACD" />

    <!-- Overlay -->
    <Color x:Key="SemiColorOverlayColor">#00000066</Color>
    <SolidColorBrush x:Key="SemiColorOverlay" Color="{StaticResource SemiColorOverlayColor}" />

    <!-- Fill -->
    <SolidColorBrush x:Key="SemiColorFill0" Color="#F9F9F9" />
    <SolidColorBrush x:Key="SemiColorFill1" Color="#F2F2F2" />
    <SolidColorBrush x:Key="SemiColorFill2" Color="#E9E9E9" />
</ResourceDictionary>
